{
  "name": "@workflow-worlds/aws",
  "version": "0.1.4",
  "description": "AWS World implementation for Workflow DevKit (DynamoDB, SQS, EventBridge Scheduler, AppSync Events)",
  "author": "Riacoding",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/riacoding/workflow-worlds.git",
    "directory": "packages/aws"
  },
  "homepage": "https://github.com/riacoding/workflow-worlds/tree/main/packages/aws#readme",
  "bugs": {
    "url": "https://github.com/riacoding/workflow-worlds/issues"
  },
  "type": "module",
  "main": "dist/index.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "pnpm --filter @workflow-worlds/testing build && pnpm build && vitest run",
    "test:only": "pnpm --filter @workflow-worlds/testing build && vitest run",
    "typecheck": "tsc --noEmit",
    "pack": "pnpm build && pnpm pack --pack-destination /tmp/workflow-aws-tarballs"
  },
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.700.0",
    "@aws-sdk/client-scheduler": "^3.700.0",
    "@aws-sdk/client-sqs": "^3.700.0",
    "@aws-sdk/lib-dynamodb": "^3.700.0",
    "@testcontainers/localstack": "^10.0.0",
    "@vercel/queue": "^0.0.0-alpha.29",
    "@workflow/errors": "4.1.4",
    "@workflow/world": "4.2.1",
    "cbor-x": "^1.6.0",
    "ulid": "^3.0.1",
    "zod": "^4.1.11"
  },
  "devDependencies": {
    "@types/node": "^22.19.1",
    "@workflow-worlds/testing": "workspace:*",
    "@workflow/world-testing": "4.1.11",
    "typescript": "^5.7.0",
    "vitest": "^4.0.18"
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "workflow",
    "world",
    "aws",
    "dynamodb",
    "sqs",
    "eventbridge",
    "appsync",
    "durable-functions"
  ],
  "publishConfig": {
    "access": "public"
  }
}