{
  "name": "@workflow-worlds/aws-infra",
  "version": "0.1.2",
  "description": "AWS CDK infrastructure for @workflow-worlds/aws (DynamoDB table, SQS queue, EventBridge Scheduler group + role)",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "synth": "cdk synth",
    "synth:dev": "cdk synth -c projectName=myapp -c stage=dev",
    "diff": "cdk diff",
    "diff:dev": "cdk diff -c projectName=myapp -c stage=dev",
    "bootstrap:dev": "cdk bootstrap -c projectName=myapp -c stage=dev",
    "deploy": "cdk deploy --outputs-file cdk-outputs.json",
    "deploy:dev": "cdk deploy --outputs-file cdk-outputs.json -c projectName=myapp -c stage=dev",
    "destroy": "cdk destroy",
    "destroy:dev": "cdk destroy -c projectName=myapp -c stage=dev",
    "print-env": "node dist/scripts/print-env.js",
    "recreate-table": "bash scripts/recreate-table.sh"
  },
  "dependencies": {
    "aws-cdk-lib": "^2.170.0",
    "constructs": "^10.4.0"
  },
  "devDependencies": {
    "@types/node": "^22.19.1",
    "aws-cdk": "^2.170.0",
    "typescript": "^5.7.0"
  }
}